# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
DEFAULT_EXPORT_TIMEZONE=America/New_York

# Standardized sizing
DEFAULT_BET_UNITS=1.0
UNIT_NOTIONAL_USD=100.0

# --- Database ---
# Set to enable persistence; app also works without DB.
DATABASE_URL=postgresql+asyncpg://pnl:pnl@localhost:5432/pnl

# --- LLM extraction (optional) ---
LLM_PROVIDER=openrouter
LLM_CHUNK_SIZE=25
LLM_MAX_CANDIDATES=120
LLM_MAX_TEXT_CHARS=500

# OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional but recommended by OpenRouter for attribution/rate limits:
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Prediction Market PnL Analyzer

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Kalshi (optional; required for accurate Kalshi matching/price/resolution) ---
KALSHI_BASE_URL=https://demo-api.kalshi.co
KALSHI_API_PREFIX=/trade-api/v2
KALSHI_KEY_ID=
# Prefer storing the PEM in a file:
KALSHI_PRIVATE_KEY_PATH=
# Or inline (single line with \n escapes):
KALSHI_PRIVATE_KEY_PEM=
# Example inline format (must be one line):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIE...REDACTED...\n...more base64...\n-----END RSA PRIVATE KEY-----\n"
# Fee multipliers (see kalshi fee schedule)
KALSHI_ASSUME_LIQUIDITY=taker
KALSHI_TAKER_FEE_MULTIPLIER=0.07
KALSHI_MAKER_FEE_MULTIPLIER=0.0175
KALSHI_INDEX_FEE_MULTIPLIER=0.035

# --- Polymarket (public market-data APIs; no key required) ---
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
